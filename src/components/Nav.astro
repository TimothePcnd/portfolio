---
---

<header class="header" id="header">

    <nav class="header__nav">
        <a href="#projects" class="header__link" data-magnetic>Projets</a>
        <a href="#about" class="header__link" data-magnetic>À propos</a>
        <a href="#contact" class="header__link" data-magnetic>Contact</a>
    </nav>

    <div class="header__side">
        <span class="header__time" id="headerTime"></span>
    </div>
</header>

<style>
    .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 48px;
        mix-blend-mode: difference;
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.8s var(--ease-out),
        transform 0.8s var(--ease-out);
    }

    .header.is-visible {
        opacity: 1;
        transform: translateY(0);
    }


    .header__nav {
        display: flex;
        gap: 48px;
        align-items: center;
    }

    .header__link {
        position: relative;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        display: inline-block;
        transition: color 0.3s var(--ease-out);
    }

    .header__link::after {
        content: '';
        position: absolute;
        bottom: -3px;
        left: 0;
        width: 0;
        height: 0.5px;
        background: #fff;
        transition: width 0.4s var(--ease-out);
    }

    .header__link:hover {
        color: #fff;
    }

    .header__link:hover::after {
        width: 100%;
    }

    .header__link.is-active {
        color: #fff;
    }

    .header__link.is-active::after {
        width: 100%;
    }

    .header__side {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header__time {
        font-size: 11px;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.3);
        font-variant-numeric: tabular-nums;
    }
</style>

<script>
    // Apparition au chargement
    window.addEventListener('load', () => {
        setTimeout(() => {
            document.getElementById('header').classList.add('is-visible');
        }, 800);
    });

    // Heure en temps réel
    function updateTime() {
        const now = new Date();
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        const el = document.getElementById('headerTime');
        if (el) el.textContent = `${h}:${m}:${s}`;
    }
    updateTime();
    setInterval(updateTime, 1000);

    // Lien actif au scroll
    const sections = ['projects', 'about', 'contact'];
    const links = document.querySelectorAll('.header__link');

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                links.forEach(l => l.classList.remove('is-active'));
                const active = document.querySelector(
                    `.header__link[href="#${entry.target.id}"]`
                );
                if (active) active.classList.add('is-active');
            }
        });
    }, { threshold: 0.5 });

    sections.forEach(id => {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
    });

    // Effet magnétique
    document.querySelectorAll('[data-magnetic]').forEach(el => {
        el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            el.style.transform = `translate(${x * 0.3}px, ${y * 0.5}px)`;
        });

        el.addEventListener('mouseleave', () => {
            el.style.transform = 'translate(0, 0)';
            el.style.transition = 'transform 0.5s var(--ease-out)';
            setTimeout(() => {
                el.style.transition = '';
            }, 500);
        });
    });
</script>