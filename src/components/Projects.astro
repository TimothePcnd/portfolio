---
const projects = [
    {
        id: '01',
        name: 'Brand Studio',
        tags: ['Web', 'Design'],
        year: '2025',
        color: '#a8ff78',
    },
    {
        id: '02',
        name: 'Dashboard UI',
        tags: ['App', 'UX'],
        year: '2025',
        color: '#78c1ff',
    },
    {
        id: '03',
        name: 'Motion Reel',
        tags: ['Motion'],
        year: '2024',
        color: '#ff78a8',
    },
    {
        id: '04',
        name: 'Brand Identity',
        tags: ['Branding'],
        year: '2024',
        color: '#ffd978',
    },
];
---

<section class="projects" id="projects">
    <div class="projects__header">
        <div class="projects__index"><span>02</span></div>
        <div class="projects__title-wrap">
            <h2 class="projects__title">Projets</h2>
            <span class="projects__hint">→ Scroll horizontal</span>
        </div>
    </div>

    <div class="projects__track-wrap">
        <div class="projects__track">
            {projects.map((project) => (
                    <article
                            class="project-card"
                            style={`--project-color: ${project.color}`}
                    >
                        <div class="project-card__thumb">
                            <span class="project-card__num">{project.id}</span>
                        </div>
                        <div class="project-card__info">
                            <div class="project-card__tags">
                                {project.tags.map(tag => (
                                        <span class="project-card__tag">{tag}</span>
                                ))}
                            </div>
                            <h3 class="project-card__name">{project.name}</h3>
                            <span class="project-card__year">{project.year}</span>
                        </div>
                    </article>
            ))}
        </div>
    </div>
</section>

<style>
    .projects {
        border-top: 0.5px solid var(--color-border);
        padding-top: var(--space-xl);
    }

    .projects__header {
        display: grid;
        grid-template-columns: 80px 1fr;
        margin-bottom: var(--space-lg);
    }

    .projects__index {
        padding: 0 var(--space-md);
        border-right: 0.5px solid var(--color-border);
        display: flex;
        align-items: flex-start;
        padding-top: 6px;
    }

    .projects__index span {
        font-size: 11px;
        letter-spacing: 0.15em;
        color: var(--color-text-muted);
        writing-mode: vertical-rl;
        text-transform: uppercase;
    }

    .projects__title-wrap {
        padding: 0 48px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .projects__title {
        font-family: var(--font-display);
        font-size: clamp(48px, 7vw, 96px);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 0.9;
    }

    .projects__hint {
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-text-muted);
    }

    .projects__track-wrap {
        overflow-x: auto;
        padding: 0 48px var(--space-xl);
        scrollbar-width: none;
    }

    .projects__track-wrap::-webkit-scrollbar {
        display: none;
    }

    .projects__track {
        display: flex;
        gap: 24px;
        width: max-content;
    }

    .project-card {
        width: 300px;
        border: 0.5px solid var(--color-border);
        border-radius: 4px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color 0.3s var(--ease-out),
        transform 0.3s var(--ease-out);
        flex-shrink: 0;
    }

    .project-card:hover {
        border-color: var(--project-color);
        transform: translateY(-4px);
    }

    .project-card__thumb {
        height: 200px;
        background: #111;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        transition: background 0.3s;
    }

    .project-card:hover .project-card__thumb {
        background: color-mix(in srgb, var(--project-color) 8%, #111);
    }

    .project-card__num {
        font-family: var(--font-display);
        font-size: 80px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.05);
        letter-spacing: -0.04em;
        transition: color 0.3s;
    }

    .project-card:hover .project-card__num {
        color: color-mix(in srgb, var(--project-color) 15%, transparent);
    }

    .project-card__info {
        padding: 20px;
        background: #0f0f0f;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .project-card__tags {
        display: flex;
        gap: 8px;
    }

    .project-card__tag {
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--project-color);
        border: 0.5px solid var(--project-color);
        padding: 3px 8px;
        border-radius: 2px;
        opacity: 0.7;
    }

    .project-card__name {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        color: var(--color-text);
    }

    .project-card__year {
        font-size: 11px;
        letter-spacing: 0.12em;
        color: var(--color-text-muted);
    }
</style>