---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Timothe Pecnard | Projet IoT">
    <div id="grid-container">
        <main class="strict-grid">

            <div class="cell col-6 flex-between">
                <span class="mono-label">TIMOTHE_PECNARD</span>
                <span class="mono-label">PROJET_ACIAL</span>
            </div>
            <div class="cell col-6 flex-right">
                <a href="/" class="mono-label accent-text hover-underline">← RETOUR_INDEX</a>
            </div>

            <!-- HERO -->
            <div class="cell col-12 hero-cell">
                <h1 class="title-massive">
                    <span class="line-wrap"><span class="gsap-reveal">IOT</span></span>
                    <span class="line-wrap"><span class="gsap-reveal align-right accent-text">ECOSYSTEME.</span></span>
                </h1>
            </div>

            <!-- METADATA -->
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ CLIENT ]</p>
                <p class="meta-value">CD41 (Loir-et-Cher)</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ RÔLE ]</p>
                <p class="meta-value">UX/UI & Dev Front</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ CONTEXTE ]</p>
                <p class="meta-value">Mandat Réel (Équipe de 4)</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between bg-number hover-accent">
                <p class="mono-label accent-text">[ STACKS ]</p>
                <div class="meta-value full-link">NEXT_LARAVEL_↗</div>
            </div>

            <!-- SPLIT SECTION (SCROLL) -->
            <div class="cell col-12 split-section">

                <!-- TEXTES (GAUCHE) -->
                <div class="split-left">

                    <div class="content-block context-block" data-image="1">
                        <span class="mono-label accent-text" style="margin-bottom: 1rem;">[ 00 / ENJEU ]</span>
                        <p class="desc-text">
                            Projet concret réalisé en conditions réelles. Le besoin du département : obtenir des données fiables pour mieux gérer cette zone touristique, et surtout ajuster au mieux les passages de l'entreprise de nettoyage. Chaque décision a été discutée et validée directement avec le client.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="1">
                        <span class="mono-label accent-text">[ 01 / UX_HARDWARE ]</span>
                        <h3 class="project-name">Stratégie Capteurs.</h3>
                        <p class="mono-desc">
                            Réflexion approfondie sur le type et le placement physique des capteurs (prévention du vol et dégradations) :
                            <br><br>
                            • <strong>Sanitaires :</strong> Seul point de passage garanti. Permet d'estimer la fréquentation et l'usure pour déclencher et optimiser les interventions de l'entreprise de nettoyage tierce.
                            <br><br>
                            • <strong>Pont de Chaumont (Eau) :</strong> Étalonné sur le point le plus bas du chemin "La Loire à Vélo". Si cette ligne est franchie, une alerte auto signale l'inaccessibilité de la piste.
                            <br><br>
                            • <strong>Météo :</strong> Collecte de données pour analyses croisées (ex: Affluence vs Temps).
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="2">
                        <span class="mono-label accent-text">[ 02 / PHASE_DESIGN ]</span>
                        <h3 class="project-name">Prototypage.</h3>
                        <p class="mono-desc">
                            Création des wireframes et maquettage haute fidélité sur Figma (Desktop & Mobile) pour les 3 livrables (Dashboard, Questionnaire QR, Carte interactive).
                            <br><br>
                            <strong>Validation :</strong> L'ensemble des parcours utilisateurs et des interfaces a été présenté physiquement au CD41. Aucune ligne de code n'a été écrite avant la validation stricte des maquettes par le client.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="2">
                        <span class="mono-label accent-text">[ 03 / PHASE_CODE ]</span>
                        <h3 class="project-name">Workflow Agile.</h3>
                        <p class="mono-desc">
                            Post-validation client : choix de la stack technologique et lancement des développements.
                            <br><br>
                            • <strong>Organisation :</strong> Découpage du projet en tickets sur GitHub. Répartition des rôles claire (API / Back-end / Front-end) au sein de l'équipe de 4.
                            <br><br>
                            • <strong>Intégration :</strong> En tant que Dev Front, utilisation de Shadcn et Next.js pour un déploiement UI rapide et modulaire, parfaitement interfacé avec l'API Laravel/MongoDB gérant les flux LoRaWAN.
                        </p>
                    </div>

                </div>

                <!-- IMAGES STICKY (DROITE) -->
                <div class="split-right">
                    <div class="sticky-wrapper">
                        <!-- Remplace les src="/..." par tes propres images exportées -->
                        <div class="visual-container active" id="img-1">
                            <img src="/iot-accueil.png" alt="Hardware Map Chaumont" class="project-img" />
                        </div>
                        <div class="visual-container" id="img-2">
                            <img src="/iot-interactive.png" alt="Figma Wireframes" class="project-img" />
                        </div>
                    </div>
                </div>

            </div>

            <!-- === NAVIGATION INTER-PROJETS === -->
            <a href="/" class="cell col-6 hover-accent footer-nav-btn nav-align-left">
                <span class="title-massive nav-text"><span class="arrow-flip">↗</span>_RETOUR_INDEX</span>
            </a>

            <a href="/projets/dashboard" class="cell col-6 hover-accent footer-nav-btn nav-align-right">
                <span class="title-massive nav-text">SUIVANT: DASHOBARD_↗</span>
            </a>

        </main>
    </div>
</Layout>

<style>
    .split-section {
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background-color: var(--grid-line); /* Ramène la bordure centrale */
    }

    .split-left {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background-color: var(--grid-line); /* Ramène les bordures horizontales */
    }

    .content-block {
        background-color: var(--bg-color); /* Rend la case blanche */
        padding: 6rem 4rem;
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .context-block { min-height: 35vh; }

    .split-right {
        background-color: var(--bg-color); /* Rend la case droite blanche */
        position: relative;
    }
    .sticky-wrapper { position: sticky; top: 0; height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; }

    .visual-container { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 90%; height: 80%; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: opacity 0.3s, visibility 0.3s; z-index: 1; }
    .visual-container.active { opacity: 1; visibility: visible; z-index: 2; }

    .project-img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }

    @media (max-width: 1024px) {
        .split-section { grid-template-columns: 1fr; }
        .sticky-wrapper { height: 50vh; position: relative; }
        .visual-container { width: 100%; height: 90%; }
        .content-block { padding: 4rem 2rem; }
    }
</style>


<script>
    import gsap from 'gsap';

    // 1. On enferme toute notre logique dans une fonction
    function initScrollImages() {
        // Animation du titre
        gsap.fromTo('.gsap-reveal',
            { y: '110%' },
            { y: '0%', duration: 1, stagger: 0.1, ease: 'power4.out', delay: 0.1 }
        );

        // Sélection des textes et configuration du détecteur
        const blocks = document.querySelectorAll('.content-block');

        const observerOptions = {
            root: null,
            rootMargin: '-30% 0px -30% 0px', // Déclenche quand le texte arrive au milieu de l'écran
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const imgId = entry.target.getAttribute('data-image');
                    if (imgId) {
                        // On cache toutes les images
                        document.querySelectorAll('.visual-container').forEach(img => {
                            img.classList.remove('active');
                        });
                        // On affiche la bonne
                        const target = document.getElementById(`img-${imgId}`);
                        if (target) {
                            target.classList.add('active');
                        }
                    }
                }
            });
        }, observerOptions);

        // On accroche le détecteur à chaque bloc de texte
        blocks.forEach(block => observer.observe(block));
    }

    // 2. LA SOLUTION : On force le lancement dans TOUS LES CAS POSSIBLES

    // Cas A : Navigation classique ou premier chargement
    document.addEventListener('DOMContentLoaded', initScrollImages);

    // Cas B : Navigation fluide Astro (View Transitions)
    document.addEventListener('astro:page-load', initScrollImages);

    // Cas C : Sécurité absolue (si le script charge en retard)
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initScrollImages();
    }
</script>