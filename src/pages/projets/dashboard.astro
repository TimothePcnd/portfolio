---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Timothe Pecnard | Dashboard Vendeur">
    <div id="grid-container">
        <main class="strict-grid">

            <div class="cell col-6 flex-between">
                <span class="mono-label">TIMOTHE PECNARD</span>
                <span class="mono-label">PROJET_DASHBOARD</span>
            </div>
            <div class="cell col-6 flex-right">
                <a href="/" class="mono-label accent-text hover-underline">← RETOUR_INDEX</a>
            </div>

            <div class="cell col-12 hero-cell">
                <h1 class="title-massive">
                    <span class="line-wrap"><span class="gsap-reveal">DASHBOARD</span></span>
                    <span class="line-wrap"><span class="gsap-reveal align-right accent-text">VENDEUR.</span></span>
                </h1>
            </div>

            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ CONTEXTE ]</p>
                <p class="meta-value">Certification DWWM</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ RÔLE ]</p>
                <p class="meta-value">Développeur Full-Stack</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ STACK ]</p>
                <p class="meta-value">Laravel / Tailwind / Chart.js</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between hover-accent">
                <p class="mono-label accent-text">[ LIEN ]</p>
                <a href="https://github.com/TimothePcnd/dashboard_cafthe.git" target="_blank" class="meta-value full-link">REPO_GITHUB_↗</a>
            </div>

            <div class="cell col-12 split-section">

                <div class="split-left">

                    <div class="content-block context-block" data-image="1">
                        <span class="mono-label accent-text" style="margin-bottom: 1rem;">[ 00 / CAHIER DES CHARGES ]</span>
                        <p class="desc-text">
                            Projet de certification finale DWWM. L'objectif : concevoir de A à Z un outil métier complet permettant de piloter l'activité de l'entreprise (gestion des stocks, produits, commandes, clients et vendeurs) tout en intégrant une interface de caisse physique.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="1">
                        <span class="mono-label accent-text">[ 01 / CONCEPTION & ARCHITECTURE ]</span>
                        <h3 class="project-name">Modélisation stricte.</h3>
                        <p class="mono-desc">
                            Méthodologie rigoureuse en amont du code : élaboration du dictionnaire de données, puis conception des modèles (MCD / MLD) soumis à la validation du formateur. Une fois l'architecture SQL validée et créée, développement de la logique backend sous Laravel (MVC, Middlewares) et intégration de l'interface avec Tailwind CSS.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="2">
                        <span class="mono-label accent-text">[ 02 / FONCTIONNALITÉS MÉTIER ]</span>
                        <h3 class="project-name">Logique de Caisse.</h3>
                        <p class="mono-desc">
                            Développement d'un module de caisse physique intégrant un modèle de panier complexe (ajout, calcul, validation). En parallèle, traitement de la donnée en PHP pour alimenter des graphiques interactifs (Chart.js) offrant une vue directe sur le Chiffre d'Affaires et les alertes de ruptures de stock.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="2">
                        <span class="mono-label accent-text">[ 03 / CONFORMITÉ ]</span>
                        <h3 class="project-name">Normes d'État.</h3>
                        <p class="mono-desc">
                            Le produit intègre les contraintes légales dès la conception : respect du RGPD pour la gestion des clients et des mots de passe hashés, ainsi qu'une interface optimisée selon les standards d'accessibilité (RGAA).
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="3">
                        <span class="mono-label accent-text">[ 04 / BILAN ]</span>
                        <h3 class="project-name">Certification validée.</h3>
                        <p class="mono-desc">
                            Projet soutenu avec succès devant le jury professionnel. Il valide la capacité à architecturer une application complexe, de la conception des tables SQL jusqu'à la logique métier du point de vente et la restitution visuelle des KPI.
                        </p>

                        <ul style="margin-top: 2rem; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.8rem;">
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>BACK :</strong></span> Modélisation MCD/MLD, Laravel, ORM Eloquent</li>
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>FRONT :</strong></span> Tailwind CSS, Dashboards interactifs Chart.js</li>
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>RÉSULTAT :</strong></span> Obtention du Titre DWWM</li>
                        </ul>
                    </div>

                </div>

                <div class="split-right">
                    <div class="sticky-wrapper">
                        <div class="visual-container active" id="img-1">
                            <img src="/cafthe-accueil.png" alt="Vue globale du Dashboard" class="project-img" />
                        </div>
                        <div class="visual-container" id="img-2">
                            <img src="/cafthe-panier.png" alt="Vue confirmation client" class="project-img" />
                        </div>
                        <div class="visual-container" id="img-3">
                            <img src="/cafthe-produit.png" alt="Vue fiche produit" class="project-img" />
                        </div>
                    </div>
                </div>

            </div>
            <a href="/" class="cell col-6 hover-accent footer-nav-btn nav-align-left">
                <span class="title-massive nav-text"><span class="arrow-flip">↗</span>_RETOUR_INDEX</span>
            </a>

            <a href="/projets/acial" class="cell col-6 hover-accent footer-nav-btn nav-align-right">
                <span class="title-massive nav-text">SUIVANT: ACIAL_↗</span>
            </a>

        </main>
    </div>
</Layout>

<style>
        /* SPLIT SECTION (Scroll) */
    .split-section {
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background-color: var(--grid-line);
    }

    .split-left {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background-color: var(--grid-line);
    }

    .content-block {
        background-color: var(--bg-color);
        padding: 6rem 4rem;
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .context-block { min-height: 35vh; }

    /* IMAGES STICKY */
    .split-right {
        background-color: var(--bg-color);
        position: relative;
    }

    .sticky-wrapper {
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        box-sizing: border-box;
    }

    .visual-container {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 90%;
        height: 80%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
        z-index: 1;
    }

    .visual-container.active {
        opacity: 1;
        visibility: visible;
        z-index: 2;
    }

    .project-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        display: block;
    }

    @media (max-width: 1024px) {
        .split-section { grid-template-columns: 1fr; }
        .sticky-wrapper { height: 50vh; position: relative; }
        .visual-container { width: 100%; height: 90%; }
        .content-block { padding: 4rem 2rem; }
    }
</style>

<script>
    import gsap from 'gsap';

    // 1. On enferme toute notre logique dans une fonction
    function initScrollImages() {
        console.log("Le script se lance enfin !"); // Pour vérifier dans la console

        // Animation du titre
        gsap.fromTo('.gsap-reveal',
            { y: '110%' },
            { y: '0%', duration: 1, stagger: 0.1, ease: 'power4.out', delay: 0.1 }
        );

        // Sélection des textes et configuration du détecteur
        const blocks = document.querySelectorAll('.content-block');

        const observerOptions = {
            root: null,
            rootMargin: '-30% 0px -30% 0px', // Déclenche quand le texte arrive au milieu de l'écran
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const imgId = entry.target.getAttribute('data-image');
                    if (imgId) {
                        // On cache toutes les images
                        document.querySelectorAll('.visual-container').forEach(img => {
                            img.classList.remove('active');
                        });
                        // On affiche la bonne
                        const target = document.getElementById(`img-${imgId}`);
                        if (target) {
                            target.classList.add('active');
                        }
                    }
                }
            });
        }, observerOptions);

        // On accroche le détecteur à chaque bloc de texte
        blocks.forEach(block => observer.observe(block));
    }

    // 2. LA SOLUTION : On force le lancement dans TOUS LES CAS POSSIBLES

    // Cas A : Navigation classique ou premier chargement
    document.addEventListener('DOMContentLoaded', initScrollImages);

    // Cas B : Navigation fluide Astro (View Transitions)
    document.addEventListener('astro:page-load', initScrollImages);

    // Cas C : Sécurité absolue (si le script charge en retard)
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initScrollImages();
    }
</script>