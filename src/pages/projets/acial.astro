---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Timothe Pecnard | Refonte Acial">
    <div id="grid-container">
        <main class="strict-grid">

            <div class="cell col-6 flex-between">
                <span class="mono-label">TIMOTHE_PECNARD</span>
                <span class="mono-label">PROJET_ACIAL</span>
            </div>
            <div class="cell col-6 flex-right">
                <a href="/" class="mono-label accent-text hover-underline">← RETOUR_INDEX</a>
            </div>

            <div class="cell col-12 hero-cell">
                <h1 class="title-massive">
                    <span class="line-wrap"><span class="gsap-reveal">ACIAL</span></span>
                    <span class="line-wrap"><span class="gsap-reveal align-right accent-text">REFONTE SITE.</span></span>
                </h1>
            </div>

            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ CLIENT ]</p>
                <p class="meta-value">Acial (Mobilier Industriel)</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ RÔLE ]</p>
                <p class="meta-value">Conception & Dev WordPress</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between">
                <p class="mono-label accent-text">[ COLLABORATION ]</p>
                <p class="meta-value">Commerce / Marketing / BE</p>
            </div>
            <div class="cell col-3 col-md-6 flex-col-between bg-number hover-accent">
                <p class="mono-label accent-text">[ LIEN ]</p>
                <a href="https://www.acial.fr" target="_blank" class="meta-value full-link">ACIAL.FR_↗</a>
            </div>

            <div class="cell col-12 split-section">

                <div class="split-left">

                    <div class="content-block context-block" data-image="1">
                        <span class="mono-label accent-text" style="margin-bottom: 1rem;">[ 00 / CONTEXTE ]</span>
                        <p class="desc-text">
                            Acial (St Aignan) disposait d'un site vieillissant. Suite à leur intégration au groupe Stow, l'objectif était de moderniser entièrement leur image B2B avec une contrainte majeure : l'utilisation obligatoire de WordPress et d'un builder imposé par le groupe.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="1">
                        <span class="mono-label accent-text">[ 01 / STRATÉGIE & UX ]</span>
                        <h3 class="project-name">Co-conception.</h3>
                        <p class="mono-desc">
                            Projet géré en solo sur la partie technique, mais en étroite collaboration avec les services Commerce, Marketing et le Bureau d'Études (BE). Création des wireframes et soutenance des maquettes directement devant le comité de direction pour validation.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="2">
                        <span class="mono-label accent-text">[ 02 / DIRECTION ARTISTIQUE ]</span>
                        <h3 class="project-name">Force de proposition.</h3>
                        <p class="mono-desc">
                            Mise en place d'une charte graphique pragmatique adaptée au secteur industriel. Proactivité sur la création de contenus textuels et la sélection iconographique pour pallier le manque de matière initiale.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="3">
                        <span class="mono-label accent-text">[ 03 / DÉVELOPPEMENT ]</span>
                        <h3 class="project-name">Intégration.</h3>
                        <p class="mono-desc">
                            Développement du site sous WordPress. Navigation entre les contraintes techniques du groupe (plugins stricts, thèmes builders) tout en garantissant un rendu final fidèle à la maquette validée par les décideurs.
                        </p>
                    </div>

                    <div class="content-block step-block" data-image="4">
                        <span class="mono-label accent-text">[ 04 / BILAN ]</span>
                        <h3 class="project-name">Livrable validé.</h3>
                        <p class="mono-desc">
                            Le projet a reçu l'entière validation de la direction. Le produit livré modernise radicalement l'image B2B d'Acial : l'architecture de l'information a été repensée pour offrir une navigation claire et un accès aux contenus optimisé. Le site est techniquement prêt pour la mise en production, en attente du shooting photographique final par les équipes internes.
                        </p>

                        <ul style="margin-top: 2rem; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.8rem;">
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>UX :</strong></span> Arborescence et parcours fluidifiés</li>
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>UI :</strong></span> Image de marque rajeunie et attractive</li>
                            <li class="mono-desc"><span class="accent-text" style="font-weight: 900;"><strong>STATUT :</strong></span> Prêt au déploiement</li>
                        </ul>
                    </div>

                </div>

                <!-- ZONE DES IMAGES STICKY -->
                <div class="split-right">
                    <div class="sticky-wrapper">
                        <div class="visual-container active" id="img-1">
                            <div class="visual-inner">
                                <span class="mono-label">[ FIGMA_WIREFRAMES ]</span>
                            </div>
                        </div>
                        <div class="visual-container" id="img-2">
                            <div class="visual-inner" style="background-color: #222; border-color: #555;">
                                <span class="mono-label" style="color: #fff;">[ DESIGN_ASSETS ]</span>
                            </div>
                        </div>
                        <div class="visual-container" id="img-3">
                            <div class="visual-inner" style="background-color: var(--accent); border-color: transparent;">
                                <span class="mono-label" style="color: #fff;">[ WORDPRESS_PROD ]</span>
                            </div>
                        </div>
                        <div class="visual-container" id="img-4">
                            <div class="visual-inner" style="background-color: #111; border-color: #333;">
                                <span class="mono-label" style="color: #fafafa;">[ STATUS_READY_TO_DEPLOY ]</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- === NAVIGATION INTER-PROJETS === -->
            <a href="/" class="cell col-6 hover-accent footer-nav-btn nav-align-left">
                <span class="title-massive nav-text"><span class="arrow-flip">↗</span>_RETOUR_INDEX</span>
            </a>

            <a href="/projets/iot" class="cell col-6 hover-accent footer-nav-btn nav-align-right">
                <span class="title-massive nav-text">PROJET_IOT_↗</span>
            </a>

        </main>
    </div>
</Layout>

<style>
    /* CSS SCOPÉ (Pas de is:global pour éviter de casser l'accueil) */

    #grid-container {
        --grid-line: #111111;
        --cell-bg: #fafafa;
        --text-main: #111111;
        --accent: #0033ff;
        padding: 1px;
        background-color: var(--grid-line);
        color: var(--text-main);
    }

    a { text-decoration: none; color: inherit; }
    h1, h3, p { margin: 0; padding: 0; }

    .strict-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1px; background-color: var(--grid-line); }

    .cell { background-color: var(--cell-bg); padding: 1.5rem; box-sizing: border-box; display: flex; flex-direction: column; }
    .col-12 { grid-column: span 12; }
    .col-6 { grid-column: span 6; }
    .col-3 { grid-column: span 3; }

    .flex-between { flex-direction: row; justify-content: space-between; align-items: center; }
    .flex-right { flex-direction: row; justify-content: flex-end; align-items: center; }
    .flex-col-between { justify-content: space-between; }
    .flex-center { justify-content: center; align-items: center; text-align: center; }
    .align-right { text-align: right; display: block; }
    .bg-number { background-color: #fafafa; }

    /* SPLIT SECTION */
    .split-section {
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background-color: var(--grid-line);
    }

    .split-left { background-color: var(--grid-line); display: flex; flex-direction: column; gap: 1px; }

    .content-block {
        background-color: var(--cell-bg);
        padding: 6rem 4rem;
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .context-block { min-height: 35vh; }

    /* STICKY VISUALS */
    .split-right { background-color: var(--cell-bg); position: relative; }

    .sticky-wrapper {
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        box-sizing: border-box;
    }

    .visual-container {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 80%;
        height: 70%;
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
        z-index: 1;
    }

    .visual-container.active { opacity: 1; z-index: 2; }

    .visual-inner {
        width: 100%; height: 100%;
        background-color: #f0f0f0; border: 1px dashed #ccc;
        display: flex; align-items: center; justify-content: center;
    }

    /* TYPO & RESPONSIVE */
    .mono-label { font-family: 'Courier New', Courier, monospace; font-size: 0.9rem; font-weight: 900; text-transform: uppercase; }
    .accent-text { color: var(--accent); }

    .hero-cell { padding: 6rem 2rem; }
    .title-massive { font-size: clamp(3rem, 10vw, 10rem); font-weight: 900; line-height: 0.8; letter-spacing: -0.05em; text-transform: uppercase; }
    .line-wrap { display: block; overflow: hidden; }
    .gsap-reveal { display: block; }

    .project-name { font-size: 3rem; font-weight: 900; letter-spacing: -0.04em; margin: 1rem 0; }
    .desc-text { font-size: 1.5rem; font-weight: 600; line-height: 1.3; }
    .mono-desc { font-family: 'Courier New', Courier, monospace; font-size: 1.05rem; color: #555; line-height: 1.5; }
    .meta-value { font-size: 1.2rem; font-weight: 700; margin-top: 0.5rem; }

    @media (max-width: 1024px) {
        .split-section { grid-template-columns: 1fr; }
        .sticky-wrapper { height: 50vh; position: relative; }
        .visual-container { width: 100%; height: 90%; }
        .col-md-6 { grid-column: span 6; }
        .content-block { padding: 4rem 2rem; }
    }

    /* HOVERS CIBLÉS */
    .hover-invert:hover { background-color: var(--text-main); color: var(--cell-bg); cursor: pointer; }

    .hover-accent { transition: background-color 0.2s; cursor: pointer; }
    .hover-accent:hover { background-color: var(--accent); }
    /* Cible uniquement les textes à l'intérieur pour les passer en blanc */
    .hover-accent:hover .mono-label,
    .hover-accent:hover .meta-value { color: #fafafa; }

    .back-btn { padding: 4rem 1.2rem; transition: background-color 0.3s, color 0.3s; }

    /* HOVERS CIBLÉS */
    .hover-invert:hover { background-color: var(--text-main); color: var(--cell-bg); cursor: pointer; }

    .hover-accent { transition: background-color 0.2s; cursor: pointer; }
    .hover-accent:hover { background-color: var(--accent); }

    /* On ajoute .nav-text pour que le lien "Projet Suivant" passe en blanc au survol */
    .hover-accent:hover .mono-label,
    .hover-accent:hover .meta-value,
    .hover-accent:hover .nav-text { color: #fafafa; }

    .back-btn { padding: 4rem 1.2rem; transition: background-color 0.3s, color 0.3s; }

    /* FOOTER NAVIGATION */
    .footer-nav-btn {
        padding: 5rem 2rem;
        transition: background-color 0.3s, color 0.3s;
        justify-content: center; /* Centre le texte verticalement dans la case */
    }

    .arrow-flip {
        display: inline-block;
        transform: rotate(-90deg);
    }

    /* Nouveaux alignements pour le footer */
    .nav-align-left {
        align-items: flex-start;
        text-align: left;
    }

    .nav-align-right {
        align-items: flex-end;
        text-align: right;
    }

    .nav-text {
        font-size: clamp(1.8rem, 4vw, 4rem);
        letter-spacing: -0.04em;
    }
</style>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    // Lenis est géré globalement dans Layout.astro

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('astro:page-load', () => {
        // 1. Reveal Hero
        gsap.fromTo('.gsap-reveal',
            { y: '110%' },
            { y: '0%', duration: 1, stagger: 0.1, ease: 'power4.out', delay: 0.1 }
        );

        // 2. Logic: Switch Images on Scroll
        const blocks = gsap.utils.toArray('.content-block');

        blocks.forEach((block: any) => {
            const imgId = block.getAttribute('data-image');

            ScrollTrigger.create({
                trigger: block,
                start: "top center",
                end: "bottom center",
                onEnter: () => switchImage(imgId),
                onEnterBack: () => switchImage(imgId)
            });
        });

        function switchImage(id: string) {
            document.querySelectorAll('.visual-container').forEach(img => {
                img.classList.remove('active');
            });
            const target = document.getElementById(`img-${id}`);
            if (target) target.classList.add('active');
        }
    });
</script>