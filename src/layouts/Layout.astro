---
interface Props {
    title?: string;
}

const { title = 'Tim Fromentin — UX & Dev' } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Tes polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
</head>

<body>
<slot /> <!-- C'est ici que tes pages viendront s'injecter -->

<script>
    import Lenis from 'lenis';

    // Smooth Scroll minimaliste et infaillible
    const lenis = new Lenis({
        duration: 1.2,
    });

    function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
</script>
</body>
</html>

<style is:global>
    /* === LE SEUL CSS GLOBAL DU SITE === */

    :root {
        --bg-color: #fafafa;
        --text-color: #111111;
        --grid-line: #e5e5e5;
        --accent: #0033ff;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Plus Jakarta Sans', sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    /* Configuration obligatoire pour Lenis */
    html.lenis, html.lenis body { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto !important; }
    .lenis.lenis-stopped { overflow: hidden; }
</style>